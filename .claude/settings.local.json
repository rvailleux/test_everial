  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"\nimport sys, json, subprocess\nd = json.load(sys.stdin)\nf = d.get('tool_input', {}).get('file_path', '') or d.get('tool_response', {}).get('filePath', '')\nif not f or not (f.endswith('.ts') or f.endswith('.tsx')):\n    sys.exit(0)\nresult = subprocess.run(['npx', 'tsc', '--noEmit'], capture_output=True, text=True, cwd='/home/user/workspace/test_everial')\noutput = (result.stdout + result.stderr).strip()\nif output:\n    print(json.dumps({'hookSpecificOutput': {'hookEventName': 'PostToolUse', 'additionalContext': 'TypeScript check after edit:\\n' + output[:2000]}}))\n\"",
            "timeout": 60,
            "statusMessage": "Type-checking...",
            "async": true
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
